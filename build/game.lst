 804D 0D		      C player_y     db START_Y
 804E 19		      C exit_x       db EXIT_COL
 804F 01		      C exit_y       db EXIT_ROW
			      C ; Boot drive is captured from DL on stage-two entry so post-boot bank reads do
			      C ; not depend on the boot sector staying resident.
 8050 00		      C boot_drive   db 0
 8051 ACE1		      C rng_state    dw 0ACE1h
