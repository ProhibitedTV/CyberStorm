				include game\state.asm
			      C ; Core run state. Most symbols are referenced directly, so only the documented
			      C ; adjacency assumptions below matter to the runtime.
 2E1E 00		      C game_state   db STATE_TITLE
 2E1F 01		      C sector_num   db 1
 2E20 05		      C shield_count db START_SHIELDS
 2E21 03		      C pulse_count  db START_PULSES
 2E22 00		      C data_count   db 0
 2E23 00		      C kill_count   db 0
 2E24 0000		      C score_total  dw 0
 2E26 0000		      C sector_score dw 0
			      C ; Sector mastery stays small and explainable: turn count feeds fast-clear bonus,
			      C ; hits gate the clean-sector bonus, and pulse usage gates the efficiency bonus.
 2E28 00		      C sector_actions     db 0
 2E29 00		      C sector_hits        db 0
 2E2A 00		      C sector_pulses_used db 0
 2E2B 00		      C message_id   db MSG_SECTOR
 2E2C 00		      C action_taken db 0
 2E2D 02		      C player_x     db START_X
 2E2E 0D		      C player_y     db START_Y
 2E2F 19		      C exit_x       db EXIT_COL
 2E30 01		      C exit_y       db EXIT_ROW
			      C ; Boot drive is captured from DL on stage-two entry so post-boot bank reads do
			      C ; not depend on the boot sector staying resident.
 2E31 00		      C boot_drive   db 0
 2E32 ACE1		      C rng_state    dw 0ACE1h
 2E34 0000		      C last_tick    dw 0
 2E36 00		      C anim_phase   db 0
 2E37 00		      C splash_ticks db 0
 2E38 00		      C state_ticks  db 0
 2E39 FF		      C last_game_state db 0FFh
 2E3A 00		      C feedback_timer db 0
			      C ; The runner's last committed step lets flanking hunters aim one tile ahead
			      C ; without any hidden extra turns or non-deterministic guesses.
 2E3B 00		      C last_player_dx db 0
 2E3C 00		      C last_player_dy db 0
			      C ; Spoof terminals briefly reroute hunters toward the gate. The timer is counted
			      C ; in enemy response phases, and spoof_x/y anchor the active route effect.
 2E3D 00		      C spoof_timer  db 0
 2E3E 02		      C spoof_x      db START_X
 2E3F 0D		      C spoof_y      db START_Y
			      C ; threat_level and threat/effect tiles are render hints only; they telegraph
			      C ; danger and localize flashes without changing the rules.
 2E40 00		      C threat_level db THREAT_NONE
 2E41 02		      C threat_x     db START_X
 2E42 0D		      C threat_y     db START_Y
 2E43 02		      C effect_x     db START_X
 2E44 0D		      C effect_y     db START_Y
			      C ; One-shot SFX owns the speaker; music state tracks the looping theme beneath it.
 2E45 00		      C sound_id     db SFX_NONE
 2E46 00		      C sound_timer  db 0
 2E47 00		      C sound_phase  db 0
 2E48 FF		      C music_theme  db MUSIC_THEME_NONE
