			      C     ; contract keeps each bank inside one 64 KiB destination segment.
 0DBE  50		      C     push ax
 0DBF  51		      C     push cx
 0DC0  52		      C     push dx
 0DC1  56		      C     push si
 0DC2  57		      C     push di
 0DC3  8B F0		      C     mov si, ax
 0DC5  8B F9		      C     mov di, cx
			      C 
