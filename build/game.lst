				include game\state.asm
			      C ; Core run state. Most symbols are referenced directly, so only the documented
			      C ; adjacency assumptions below matter to the runtime.
 803B 00		      C game_state   db STATE_TITLE
 803C 01		      C sector_num   db 1
			      C ; current_template_index keeps the selected authored map slot so hybrid anchor
			      C ; placement can read the right generated tables after copy_sector_layout.
 803D 00		      C current_template_index db 0
			      C ; shard_pool_pick_mask is a sector-load scratch bitmask used while selecting
			      C ; 4 unique live shard positions from the authored 6-tile scenario pool.
 803E 00		      C shard_pool_pick_mask db 0
 803F 05		      C shield_count db START_SHIELDS
 8040 03		      C pulse_count  db START_PULSES
 8041 00		      C data_count   db 0
 8042 00		      C kill_count   db 0
 8043 0000		      C score_total  dw 0
 8045 0000		      C sector_score dw 0
			      C ; Sector mastery stays small and explainable: turn count feeds fast-clear bonus,
			      C ; hits gate the clean-sector bonus, and pulse usage gates the efficiency bonus.
 8047 00		      C sector_actions     db 0
 8048 00		      C sector_hits        db 0
 8049 00		      C sector_pulses_used db 0
 804A 00		      C message_id   db MSG_SECTOR
 804B 00		      C action_taken db 0
