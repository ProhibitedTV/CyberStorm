 91C5 00		      C adventure_charge_timer   db 0
 91C6 00		      C adventure_flame_timer    db 0
 91C7 00		      C adventure_enemy_tick     db 0
 91C8 00		      C adventure_hazard_timer   db 0
 91C9 00		      C adventure_objectives_done db 0
 91CA 00		      C adventure_objectives_total db 0
 91CB 00		      C adventure_intro_timer    db 0
 91CC 00		      C adventure_key_collected  db 0
