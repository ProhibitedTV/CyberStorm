				include game\state.asm
			      C ; Core run state. Most symbols are referenced directly, so only the documented
			      C ; adjacency assumptions below matter to the runtime.
 909C 00		      C game_state   db STATE_TITLE
 909D 01		      C sector_num   db 1
			      C ; current_template_index keeps the selected authored map slot so hybrid anchor
			      C ; placement can read the right generated tables after copy_sector_layout.
 909E 00		      C current_template_index db 0
			      C ; shard_pool_pick_mask is a sector-load scratch bitmask used while selecting
			      C ; 4 unique live shard positions from the authored 6-tile scenario pool.
 909F 00		      C shard_pool_pick_mask db 0
 90A0 05		      C shield_count db START_SHIELDS
 90A1 03		      C pulse_count  db START_PULSES
 90A2 00		      C data_count   db 0
 90A3 00		      C kill_count   db 0
 90A4 0000		      C score_total  dw 0
 90A6 0000		      C sector_score dw 0
			      C ; Sector mastery stays small and explainable: turn count feeds fast-clear bonus,
			      C ; hits gate the clean-sector bonus, and pulse usage gates the efficiency bonus.
 90A8 00		      C sector_actions     db 0
 90A9 00		      C sector_hits        db 0
 90AA 00		      C sector_pulses_used db 0
 90AB 00		      C message_id   db MSG_SECTOR
 90AC 00		      C action_taken db 0
 90AD 02		      C player_x     db START_X
 90AE 0D		      C player_y     db START_Y
 90AF 19		      C exit_x       db EXIT_COL
 90B0 01		      C exit_y       db EXIT_ROW
 90B1 0000		      C adventure_player_world_x dw 0
 90B3 FF00		      C adventure_player_world_y dw GAME3D_FLOOR_Y
 90B5 0000		      C adventure_player_world_z dw 0
 90B7 0000		      C adventure_player_vel_y   dw 0
 90B9 80		      C adventure_player_yaw     db GAME3D_YAW_NORTH
 90BA 01		      C adventure_player_grounded db 1
 90BB 00		      C adventure_charge_timer   db 0
 90BC 00		      C adventure_flame_timer    db 0
 90BD 00		      C adventure_enemy_tick     db 0
 90BE 00		      C adventure_hazard_timer   db 0
 90BF 00		      C adventure_objectives_done db 0
 90C0 00		      C adventure_objectives_total db 0
 90C1 00		      C adventure_intro_timer    db 0
 90C2 00		      C adventure_key_collected  db 0
 90C3 FF		      C adventure_chunk_x        db 0FFh
 90C4 FF		      C adventure_chunk_y        db 0FFh
 90C5 00		      C adventure_chunk_min_x    db 0
 90C6 1B		      C adventure_chunk_max_x    db MAP_W - 1
 90C7 00		      C adventure_chunk_min_y    db 0
 90C8 0E		      C adventure_chunk_max_y    db MAP_H - 1
			      C ; Boot drive is captured from DL on stage-two entry so post-boot bank reads do
			      C ; not depend on the boot sector staying resident.
 90C9 00		      C boot_drive   db 0
 90CA ACE1		      C rng_state    dw 0ACE1h
 90CC 0000		      C last_tick    dw 0
 90CE 0000		      C pit_frame_due_low dw 0
 90D0 0000		      C pit_frame_due_high dw 0
 90D2 00		      C frame_skip_render db 0
 90D3 00		      C anim_phase   db 0
 90D4 00		      C splash_ticks db 0
 90D5 00		      C state_ticks  db 0
 90D6 00		      C title_idle_ticks db 0
			      C ; A short post-start guard keeps freshly entered runs from immediately honoring
			      C ; reset input on the next gameplay tick while frontend keys are settling.
 90D7 00		      C run_start_enter_guard db 0
			      C ; Demo playback is opt-in attract mode driven by generated [action, ticks]
