				include game\state.asm
			      C ; Core run state. Most symbols are referenced directly, so only the documented
			      C ; adjacency assumptions below matter to the runtime.
 4235 00		      C game_state   db STATE_TITLE
 4236 01		      C sector_num   db 1
			      C ; current_template_index keeps the selected authored map slot so hybrid anchor
			      C ; placement can read the right generated tables after copy_sector_layout.
 4237 00		      C current_template_index db 0
			      C ; shard_pool_pick_mask is a sector-load scratch bitmask used while selecting
			      C ; 4 unique live shard positions from the authored 6-tile scenario pool.
 4238 00		      C shard_pool_pick_mask db 0
 4239 05		      C shield_count db START_SHIELDS
 423A 03		      C pulse_count  db START_PULSES
 423B 00		      C data_count   db 0
 423C 00		      C kill_count   db 0
 423D 0000		      C score_total  dw 0
 423F 0000		      C sector_score dw 0
			      C ; Sector mastery stays small and explainable: turn count feeds fast-clear bonus,
			      C ; hits gate the clean-sector bonus, and pulse usage gates the efficiency bonus.
 4241 00		      C sector_actions     db 0
 4242 00		      C sector_hits        db 0
 4243 00		      C sector_pulses_used db 0
 4244 00		      C message_id   db MSG_SECTOR
 4245 00		      C action_taken db 0
 4246 02		      C player_x     db START_X
 4247 0D		      C player_y     db START_Y
 4248 19		      C exit_x       db EXIT_COL
 4249 01		      C exit_y       db EXIT_ROW
			      C ; Boot drive is captured from DL on stage-two entry so post-boot bank reads do
			      C ; not depend on the boot sector staying resident.
 424A 00		      C boot_drive   db 0
 424B ACE1		      C rng_state    dw 0ACE1h
 424D 0000		      C last_tick    dw 0
 424F 00		      C anim_phase   db 0
 4250 00		      C splash_ticks db 0
 4251 00		      C state_ticks  db 0
 4252 00		      C title_idle_ticks db 0
			      C ; A short post-start guard keeps freshly entered runs from immediately honoring
			      C ; reset input on the next gameplay tick while frontend keys are settling.
 4253 00		      C run_start_enter_guard db 0
			      C ; Demo playback is opt-in attract mode driven by generated [action, ticks]
			      C ; pairs. next_demo_index rotates the title idle cycle through the authored set.
 4254 00		      C demo_active  db 0
 4255 00		      C demo_index   db 0
 4256 00		      C next_demo_index db 0
 4257 00		      C demo_action_code db DEMO_ACTION_END
 4258 00		      C demo_action_ticks db 0
 4259 0000		      C demo_script_ptr dw 0
			      C ; Debug-only replay verification tracks consumed demo actions separately from
			      C ; action_taken so blocked moves and other no-turn inputs can still be checked.
 425B 00		      C verify_action_pending db 0
 425C 00		      C verify_action_index db 0
 425D 00		      C verify_result_demo_index db 0
 425E 0000		      C verify_expected_signature dw 0
 4260 0000		      C verify_observed_signature dw 0
 4262 FF		      C last_game_state db 0FFh
 4263 00		      C feedback_timer db 0
			      C ; The runner's last committed step lets flanking hunters aim one tile ahead
			      C ; without any hidden extra turns or non-deterministic guesses.
 4264 00		      C last_player_dx db 0
 4265 00		      C last_player_dy db 0
			      C ; Spoof terminals briefly reroute hunters toward the gate. The timer is counted
			      C ; in enemy response phases, and spoof_x/y anchor the active route effect.
 4266 00		      C spoof_timer  db 0
 4267 02		      C spoof_x      db START_X
 4268 0D		      C spoof_y      db START_Y
			      C ; threat_level and threat/effect tiles are render hints only; they telegraph
			      C ; danger and localize flashes without changing the rules.
 4269 00		      C threat_level db THREAT_NONE
 426A 02		      C threat_x     db START_X
 426B 0D		      C threat_y     db START_Y
 426C 02		      C effect_x     db START_X
 426D 0D		      C effect_y     db START_Y
			      C ; One-shot SFX owns the speaker; music state tracks the looping theme beneath it.
 426E 00		      C sound_id     db SFX_NONE
 426F 00		      C sound_timer  db 0
 4270 00		      C sound_phase  db 0
 4271 FF		      C music_theme  db MUSIC_THEME_NONE
 4272 00		      C music_ticks  db 0
 4273 00		      C music_note   db MUSIC_NOTE_REST
 4274 0000		      C music_ptr    dw 0
 4276 00		      C key_extended db 0
 4277 00		      C any_key_pending db 0
 4278 00		      C input_event_count db 0
 4279 00		      C input_last_code db 0
 427A 00		      C input_check_count db 0
 427B 00		      C input_poll_count db 0
 427C 00		      C input_last_polled db 0
 427D 00		      C pressed_enter db 0
 427E 00		      C pressed_w db 0
 427F 00		      C pressed_a db 0
 4280 00		      C pressed_s db 0
 4281 00		      C pressed_d db 0
 4282 00		      C pressed_r db 0
 4283 00		      C pressed_c db 0
 4284 00		      C pressed_up db 0
 4285 00		      C pressed_left db 0
 4286 00		      C pressed_right db 0
 4287 00		      C pressed_down db 0
			      C ; key_down and key_pressed must stay adjacent because reset_keyboard_state
			      C ; clears one contiguous KEY_STATE_REGION_BYTES block starting here.
 4288  0100 [		      C key_down db KEY_STATE_TABLE_BYTES dup (0)
        00
       ]
			      C ; Reserved for future/diagnostic per-scan bookkeeping.
 4388  0100 [		      C key_pressed db KEY_STATE_TABLE_BYTES dup (0)
        00
       ]
			      C 
 4488 0000		      C text_cursor_x  dw 0
 448A 0000		      C text_cursor_y  dw 0
 448C 0000		      C glyph_base_x   dw 0
 448E 0000		      C glyph_base_y   dw 0
 4490 0000		      C rect_w         dw 0
 4492 0000		      C rect_h         dw 0
 4494 00		      C text_color     db 0
 4495 00		      C glyph_row_bits db 0
			      C 
			      C ; Enemy slot layout: [alive, x, y, kind].
 4496  0028 [		      C enemies db MAX_ENEMIES * ENEMY_SIZE dup (0)
        00
       ]
 44BE  01A4 [		      C map_tiles db MAP_SIZE dup (0)
        00
       ]
			      C 
			      C ; map_index depends on these row bases matching MAP_W exactly.
 4662 0000 001C 0038 0054     C map_row_offsets dw 0, 28, 56, 84, 112, 140, 168, 196, 224, 252, 280, 308, 336, 364, 392
       0070 008C 00A8
       00C4 00E0 00FC
       0118 0134 0150
       016C 0188
 4680  0003 [		      C sector_score_table dw TOTAL_SECTORS dup (0)
        0000
       ]
