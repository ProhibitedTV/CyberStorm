				include game\state.asm
			      C ; Core run state. Most symbols are referenced directly, so only the documented
			      C ; adjacency assumptions below matter to the runtime.
 36A4 00		      C game_state   db STATE_TITLE
 36A5 01		      C sector_num   db 1
 36A6 05		      C shield_count db START_SHIELDS
 36A7 03		      C pulse_count  db START_PULSES
 36A8 00		      C data_count   db 0
 36A9 00		      C kill_count   db 0
 36AA 0000		      C score_total  dw 0
 36AC 0000		      C sector_score dw 0
			      C ; Sector mastery stays small and explainable: turn count feeds fast-clear bonus,
			      C ; hits gate the clean-sector bonus, and pulse usage gates the efficiency bonus.
 36AE 00		      C sector_actions     db 0
 36AF 00		      C sector_hits        db 0
 36B0 00		      C sector_pulses_used db 0
 36B1 00		      C message_id   db MSG_SECTOR
 36B2 00		      C action_taken db 0
 36B3 02		      C player_x     db START_X
 36B4 0D		      C player_y     db START_Y
 36B5 19		      C exit_x       db EXIT_COL
 36B6 01		      C exit_y       db EXIT_ROW
			      C ; Boot drive is captured from DL on stage-two entry so post-boot bank reads do
			      C ; not depend on the boot sector staying resident.
 36B7 00		      C boot_drive   db 0
 36B8 ACE1		      C rng_state    dw 0ACE1h
 36BA 0000		      C last_tick    dw 0
 36BC 00		      C anim_phase   db 0
 36BD 00		      C splash_ticks db 0
 36BE 00		      C state_ticks  db 0
 36BF 00		      C title_idle_ticks db 0
			      C ; A short post-start guard keeps freshly entered runs from immediately honoring
			      C ; reset input on the next gameplay tick while frontend keys are settling.
 36C0 00		      C run_start_enter_guard db 0
			      C ; Demo playback is opt-in attract mode driven by generated [action, ticks]
			      C ; pairs. next_demo_index rotates the title idle cycle through the authored set.
 36C1 00		      C demo_active  db 0
 36C2 00		      C demo_index   db 0
 36C3 00		      C next_demo_index db 0
 36C4 00		      C demo_action_code db DEMO_ACTION_END
 36C5 00		      C demo_action_ticks db 0
 36C6 0000		      C demo_script_ptr dw 0
 36C8 FF		      C last_game_state db 0FFh
 36C9 00		      C feedback_timer db 0
			      C ; The runner's last committed step lets flanking hunters aim one tile ahead
			      C ; without any hidden extra turns or non-deterministic guesses.
 36CA 00		      C last_player_dx db 0
 36CB 00		      C last_player_dy db 0
			      C ; Spoof terminals briefly reroute hunters toward the gate. The timer is counted
			      C ; in enemy response phases, and spoof_x/y anchor the active route effect.
 36CC 00		      C spoof_timer  db 0
 36CD 02		      C spoof_x      db START_X
 36CE 0D		      C spoof_y      db START_Y
			      C ; threat_level and threat/effect tiles are render hints only; they telegraph
			      C ; danger and localize flashes without changing the rules.
 36CF 00		      C threat_level db THREAT_NONE
 36D0 02		      C threat_x     db START_X
 36D1 0D		      C threat_y     db START_Y
 36D2 02		      C effect_x     db START_X
 36D3 0D		      C effect_y     db START_Y
			      C ; One-shot SFX owns the speaker; music state tracks the looping theme beneath it.
 36D4 00		      C sound_id     db SFX_NONE
 36D5 00		      C sound_timer  db 0
 36D6 00		      C sound_phase  db 0
 36D7 FF		      C music_theme  db MUSIC_THEME_NONE
 36D8 00		      C music_ticks  db 0
 36D9 00		      C music_note   db MUSIC_NOTE_REST
 36DA 0000		      C music_ptr    dw 0
 36DC 00		      C key_extended db 0
 36DD 00		      C any_key_pending db 0
 36DE 00		      C input_event_count db 0
 36DF 00		      C input_last_code db 0
 36E0 00		      C input_check_count db 0
 36E1 00		      C input_poll_count db 0
 36E2 00		      C input_last_polled db 0
 36E3 00		      C pressed_enter db 0
 36E4 00		      C pressed_w db 0
 36E5 00		      C pressed_a db 0
 36E6 00		      C pressed_s db 0
 36E7 00		      C pressed_d db 0
 36E8 00		      C pressed_r db 0
 36E9 00		      C pressed_c db 0
 36EA 00		      C pressed_up db 0
 36EB 00		      C pressed_left db 0
 36EC 00		      C pressed_right db 0
 36ED 00		      C pressed_down db 0
			      C ; key_down and key_pressed must stay adjacent because reset_keyboard_state
			      C ; clears one contiguous KEY_STATE_REGION_BYTES block starting here.
 36EE  0100 [		      C key_down db KEY_STATE_TABLE_BYTES dup (0)
        00
       ]
			      C ; Reserved for future/diagnostic per-scan bookkeeping.
 37EE  0100 [		      C key_pressed db KEY_STATE_TABLE_BYTES dup (0)
        00
       ]
