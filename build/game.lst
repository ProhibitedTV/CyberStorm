			      C 
			      C ; The starfield, palette, and font are still hand-authored assembly data because
			      C ; they are compact, low churn, and easier to reason about directly in-source.
 = 0010			      C STAR_COUNT equ 16
 EB5E 0018 0012 0005	      C starfield  dw 24, 18, PAL_CYAN
 EB64  003E 001C 0007	      C            dw 62, 28, PAL_WHITE
 EB6A  006E 000C 0005	      C            dw 110, 12, PAL_CYAN
 EB70  00B6 0016 0007	      C            dw 182, 22, PAL_WHITE
 EB76  00EE 0012 0005	      C            dw 238, 18, PAL_CYAN
 EB7C  012A 001A 0007	      C            dw 298, 26, PAL_WHITE
 EB82  0024 00B0 0005	      C            dw 36, 176, PAL_CYAN
 EB88  0058 00BC 0007	      C            dw 88, 188, PAL_WHITE
 EB8E  008C 00B6 0005	      C            dw 140, 182, PAL_CYAN
 EB94  00D2 00BE 0007	      C            dw 210, 190, PAL_WHITE
 EB9A  0118 00B2 0005	      C            dw 280, 178, PAL_CYAN
 EBA0  0130 0096 0007	      C            dw 304, 150, PAL_WHITE
 EBA6  000E 0062 0005	      C            dw 14, 98, PAL_CYAN
 EBAC  0134 004A 0007	      C            dw 308, 74, PAL_WHITE
 EBB2  011E 0036 0005	      C            dw 286, 54, PAL_CYAN
 EBB8  0008 0090 0007	      C            dw 8, 144, PAL_WHITE
			      C 
 EBBE 00 00 00		      C palette_data db 0,0,0
 EBC1  02 03 08		      C              db 2,3,8
 EBC4  04 07 0E		      C              db 4,7,14
 EBC7  05 0A 12		      C              db 5,10,18
