				include game\state.asm
			      C ; Core run state. Most symbols are referenced directly, so only the documented
			      C ; adjacency assumptions below matter to the runtime.
 3512 00		      C game_state   db STATE_TITLE
 3513 01		      C sector_num   db 1
 3514 05		      C shield_count db START_SHIELDS
 3515 03		      C pulse_count  db START_PULSES
 3516 00		      C data_count   db 0
 3517 00		      C kill_count   db 0
 3518 0000		      C score_total  dw 0
 351A 0000		      C sector_score dw 0
			      C ; Sector mastery stays small and explainable: turn count feeds fast-clear bonus,
			      C ; hits gate the clean-sector bonus, and pulse usage gates the efficiency bonus.
 351C 00		      C sector_actions     db 0
 351D 00		      C sector_hits        db 0
 351E 00		      C sector_pulses_used db 0
 351F 00		      C message_id   db MSG_SECTOR
 3520 00		      C action_taken db 0
 3521 02		      C player_x     db START_X
 3522 0D		      C player_y     db START_Y
 3523 19		      C exit_x       db EXIT_COL
 3524 01		      C exit_y       db EXIT_ROW
			      C ; Boot drive is captured from DL on stage-two entry so post-boot bank reads do
			      C ; not depend on the boot sector staying resident.
 3525 00		      C boot_drive   db 0
 3526 ACE1		      C rng_state    dw 0ACE1h
 3528 0000		      C last_tick    dw 0
 352A 00		      C anim_phase   db 0
 352B 00		      C splash_ticks db 0
 352C 00		      C state_ticks  db 0
 352D 00		      C title_idle_ticks db 0
			      C ; A short Enter guard after leaving splash/title prevents the start key from
			      C ; immediately retriggering the in-run reset binding on the next gameplay tick.
 352E 00		      C run_start_enter_guard db 0
			      C ; Demo playback is opt-in attract mode driven by generated [action, ticks]
			      C ; pairs. next_demo_index rotates the title idle cycle through the authored set.
 352F 00		      C demo_active  db 0
 3530 00		      C demo_index   db 0
 3531 00		      C next_demo_index db 0
 3532 00		      C demo_action_code db DEMO_ACTION_END
 3533 00		      C demo_action_ticks db 0
 3534 0000		      C demo_script_ptr dw 0
 3536 FF		      C last_game_state db 0FFh
 3537 00		      C feedback_timer db 0
			      C ; The runner's last committed step lets flanking hunters aim one tile ahead
			      C ; without any hidden extra turns or non-deterministic guesses.
 3538 00		      C last_player_dx db 0
 3539 00		      C last_player_dy db 0
			      C ; Spoof terminals briefly reroute hunters toward the gate. The timer is counted
			      C ; in enemy response phases, and spoof_x/y anchor the active route effect.
 353A 00		      C spoof_timer  db 0
 353B 02		      C spoof_x      db START_X
 353C 0D		      C spoof_y      db START_Y
			      C ; threat_level and threat/effect tiles are render hints only; they telegraph
			      C ; danger and localize flashes without changing the rules.
 353D 00		      C threat_level db THREAT_NONE
