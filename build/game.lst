			      C 
				include game\maps.asm
			      C ; Phase-1 asset banks moved the authored map pool out of stage two.
			      C ; The readable map source still builds to build\generated_maps.inc for review,
			      C ; but gameplay now reads the raw payload from MAP_BANK_SEG via
			      C ; template_offset_table in generated_sector_content.inc.
			      C 
				include game\render\enhanced_present.asm
			      C .386p
			      C 
 F5CA			      C init_video_output:
 F5CA  50		      C     push ax
 F5CB  53		      C     push bx
 F5CC  06		      C     push es
			      C 
 F5CD  2E: C6 06 A5B1 R	      C     mov byte ptr [video_output_mode], ENHANCED_OUTPUT_MODE_OFF
       00
 F5D3  2E: C7 06 A5B2 R	      C     mov word ptr [video_pitch], SCREEN_W
       0140
 F5DA  2E: C7 06 A5B4 R	      C     mov word ptr [video_output_w], SCREEN_W
       0140
 F5E1  2E: C7 06 A5B6 R	      C     mov word ptr [video_output_h], SCREEN_H
       00C8
 F5E8  66| 2E: C7 06 A5B8 R   C     mov dword ptr [video_lfb_addr], 0
       00000000
			      C 
 F5F2  B8 0800		      C     mov ax, BOOTSTRAP_SEG
 F5F5  8E C0		      C     mov es, ax
 F5F7  BB 0400		      C     mov bx, ENHANCED_HANDOFF_OFFSET
 F5FA  26: 8B 07	      C     mov ax, word ptr es:[bx + ENHANCED_HANDOFF_SIG0_OFF]
 F5FD  3D 4252		      C     cmp ax, ENHANCED_HANDOFF_SIG0
 F600  75 3C		      C     jne init_video_output_legacy
 F602  26: 8B 47 02	      C     mov ax, word ptr es:[bx + ENHANCED_HANDOFF_SIG1_OFF]
 F606  3D 5645		      C     cmp ax, ENHANCED_HANDOFF_SIG1
 F609  75 33		      C     jne init_video_output_legacy
 F60B  26: 8B 47 06	      C     mov ax, word ptr es:[bx + ENHANCED_HANDOFF_FLAGS_OFF]
 F60F  A9 0001		      C     test ax, ENHANCED_HANDOFF_FLAG_VBE
 F612  74 2A		      C     jz init_video_output_legacy
			      C 
 F614  2E: C6 06 A5B1 R	      C     mov byte ptr [video_output_mode], ENHANCED_OUTPUT_MODE_VBE
       01
 F61A  26: 8B 47 0E	      C     mov ax, word ptr es:[bx + ENHANCED_HANDOFF_PITCH_OFF]
 F61E  2E: A3 A5B2 R	      C     mov word ptr [video_pitch], ax
 F622  26: 8B 47 0A	      C     mov ax, word ptr es:[bx + ENHANCED_HANDOFF_WIDTH_OFF]
 F626  2E: A3 A5B4 R	      C     mov word ptr [video_output_w], ax
 F62A  26: 8B 47 0C	      C     mov ax, word ptr es:[bx + ENHANCED_HANDOFF_HEIGHT_OFF]
 F62E  2E: A3 A5B6 R	      C     mov word ptr [video_output_h], ax
 F632  66| 26: 8B 47 10	      C     mov eax, dword ptr es:[bx + ENHANCED_HANDOFF_LFB_OFF]
 F637  66| 2E: A3 A5B8 R      C     mov dword ptr [video_lfb_addr], eax
 F63C  EB 05		      C     jmp init_video_output_done
			      C 
 F63E			      C init_video_output_legacy:
 F63E  B8 0013		      C     mov ax, 0013h
 F641  CD 10		      C     int 10h
			      C 
 F643			      C init_video_output_done:
 F643  07		      C     pop es
 F644  5B		      C     pop bx
 F645  58		      C     pop ax
 F646  C3		      C     ret
			      C 
 F647			      C refresh_vbe_flat_fs:
 F647  50		      C     push ax
 F648  53		      C     push bx
 F649  1E		      C     push ds
 F64A  FA		      C     cli
 F64B  0E		      C     push cs
 F64C  1F		      C     pop ds
			      C 
 F64D  66| 33 C0	      C     xor eax, eax
 F650  8C C8		      C     mov ax, cs
 F652  66| C1 E0 04	      C     shl eax, 4
 F656  2E: A3 F7E6 R	      C     mov word ptr [vbe_flat_gdt_code + 2], ax
 F65A  66| C1 E8 10	      C     shr eax, 16
 F65E  2E: A2 F7E8 R	      C     mov byte ptr [vbe_flat_gdt_code + 4], al
 F662  2E: 88 26 F7EB R	      C     mov byte ptr [vbe_flat_gdt_code + 7], ah
			      C 
 F667  66| 33 C0	      C     xor eax, eax
 F66A  8C C8		      C     mov ax, cs
 F66C  66| C1 E0 04	      C     shl eax, 4
 F670  66| 05 0000F7DC R      C     add eax, OFFSET vbe_flat_gdt_start
 F676  66| 2E: A3 F7F6 R      C     mov dword ptr [vbe_flat_gdt_descriptor + 2], eax
			      C 
 F67B  2E: 0F 01 16 F7F4 R    C     lgdt fword ptr [vbe_flat_gdt_descriptor]
 F681  0F 20 C0		      C     mov eax, cr0
 F684  66| 83 C8 01	      C     or eax, 1
 F688  0F 22 C0		      C     mov cr0, eax
 F68B  6A 08		      C     push VBE_FLAT_CODE_SEL
 F68D  68 F691 R	      C     push OFFSET refresh_vbe_flat_fs_protected
