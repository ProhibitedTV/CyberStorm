				include game\state.asm
			      C ; Core run state. Most symbols are referenced directly, so only the documented
			      C ; adjacency assumptions below matter to the runtime.
 93E7 00		      C game_state   db STATE_TITLE
 93E8 01		      C sector_num   db 1
			      C ; current_template_index keeps the selected authored map slot so hybrid anchor
			      C ; placement can read the right generated tables after copy_sector_layout.
 93E9 00		      C current_template_index db 0
			      C ; shard_pool_pick_mask is a sector-load scratch bitmask used while selecting
			      C ; 4 unique live shard positions from the authored 6-tile scenario pool.
 93EA 00		      C shard_pool_pick_mask db 0
 93EB 05		      C shield_count db START_SHIELDS
 93EC 03		      C pulse_count  db START_PULSES
 93ED 00		      C data_count   db 0
 93EE 00		      C kill_count   db 0
 93EF 0000		      C score_total  dw 0
 93F1 0000		      C sector_score dw 0
			      C ; Sector mastery stays small and explainable: turn count feeds fast-clear bonus,
			      C ; hits gate the clean-sector bonus, and pulse usage gates the efficiency bonus.
 93F3 00		      C sector_actions     db 0
 93F4 00		      C sector_hits        db 0
 93F5 00		      C sector_pulses_used db 0
 93F6 00		      C message_id   db MSG_SECTOR
 93F7 00		      C action_taken db 0
 93F8 02		      C player_x     db START_X
 93F9 0D		      C player_y     db START_Y
 93FA 19		      C exit_x       db EXIT_COL
 93FB 01		      C exit_y       db EXIT_ROW
 93FC 0000		      C adventure_player_world_x dw 0
 93FE FF00		      C adventure_player_world_y dw GAME3D_FLOOR_Y
 9400 0000		      C adventure_player_world_z dw 0
 9402 0000		      C adventure_player_vel_y   dw 0
 9404 80		      C adventure_player_yaw     db GAME3D_YAW_NORTH
 9405 01		      C adventure_player_grounded db 1
 9406 00		      C adventure_charge_timer   db 0
 9407 00		      C adventure_flame_timer    db 0
 9408 00		      C adventure_enemy_tick     db 0
 9409 00		      C adventure_hazard_timer   db 0
 940A 00		      C adventure_objectives_done db 0
 940B 00		      C adventure_objectives_total db 0
 940C 00		      C adventure_intro_timer    db 0
 940D 00		      C adventure_key_collected  db 0
 940E FF		      C adventure_chunk_x        db 0FFh
 940F FF		      C adventure_chunk_y        db 0FFh
 9410 00		      C adventure_chunk_min_x    db 0
 9411 1B		      C adventure_chunk_max_x    db MAP_W - 1
 9412 00		      C adventure_chunk_min_y    db 0
 9413 0E		      C adventure_chunk_max_y    db MAP_H - 1
			      C ; Boot drive is captured from DL on stage-two entry so post-boot bank reads do
			      C ; not depend on the boot sector staying resident.
 9414 00		      C boot_drive   db 0
 9415 ACE1		      C rng_state    dw 0ACE1h
 9417 0000		      C last_tick    dw 0
 9419 0000		      C pit_frame_due_low dw 0
 941B 0000		      C pit_frame_due_high dw 0
 941D 00		      C frame_skip_render db 0
 941E 00		      C anim_phase   db 0
 941F 00		      C splash_ticks db 0
 9420 00		      C state_ticks  db 0
 9421 00		      C title_idle_ticks db 0
			      C ; A short post-start guard keeps freshly entered runs from immediately honoring
			      C ; reset input on the next gameplay tick while frontend keys are settling.
 9422 00		      C run_start_enter_guard db 0
			      C ; Demo playback is opt-in attract mode driven by generated [action, ticks]
			      C ; pairs. next_demo_index rotates the title idle cycle through the authored set.
 9423 00		      C demo_active  db 0
 9424 00		      C demo_index   db 0
 9425 00		      C next_demo_index db 0
 9426 00		      C demo_action_code db DEMO_ACTION_END
 9427 00		      C demo_action_ticks db 0
 9428 0000		      C demo_script_ptr dw 0
			      C ; Debug-only replay verification tracks consumed demo actions separately from
			      C ; action_taken so blocked moves and other no-turn inputs can still be checked.
 942A 00		      C verify_action_pending db 0
 942B 00		      C verify_action_index db 0
 942C 00		      C verify_result_demo_index db 0
 942D 0000		      C verify_expected_signature dw 0
 942F 0000		      C verify_observed_signature dw 0
			      C ; verify_mode reuses the shared PASS/FAIL scenes for both replay verification
			      C ; and the debug-only frontend trust scenarios.
 9431 00		      C verify_mode db VERIFY_MODE_REPLAY
 9432 00		      C verify_frontend_scenario db FRONTEND_VERIFY_NONE
 9433 00		      C verify_frontend_ticks db 0
 9434 00		      C verify_frontend_event_fired db 0
 9435 FF		      C last_game_state db 0FFh
 9436 00		      C feedback_timer db 0
			      C ; The runner's last committed step lets flanking hunters aim one tile ahead
			      C ; without any hidden extra turns or non-deterministic guesses.
 9437 00		      C last_player_dx db 0
 9438 00		      C last_player_dy db 0
			      C ; Spoof terminals briefly reroute hunters toward the gate. The timer is counted
			      C ; in enemy response phases, and spoof_x/y anchor the active route effect.
