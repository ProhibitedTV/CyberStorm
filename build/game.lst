 A0AF 00		      C data_count   db 0
 A0B0 00		      C kill_count   db 0
 A0B1 00		      C checkpoint_kill_count db 0
 A0B2 0000		      C score_total  dw 0
 A0B4 0000		      C checkpoint_score_total dw 0
 A0B6 0000		      C sector_score dw 0
			      C ; Sector mastery stays small and explainable: turn count feeds fast-clear bonus,
			      C ; hits gate the clean-sector bonus, and pulse usage gates the efficiency bonus.
