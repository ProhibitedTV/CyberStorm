			      C ; A short rounded waveform keeps the experimental music path less piercing than
			      C ; the earlier hard-edged square-wave approach while still staying period-lean.
 08F8 00 06 0C 12 17 1C	      C sb16_waveform db 0, 6, 12, 18, 23, 28, 31, 34
       1F 22
 0900  24 22 1F 1C 17 12      C               db 36, 34, 31, 28, 23, 18, 12, 6
       0C 06
 0908  00 FA F4 EE E9 E4      C               db 0, -6, -12, -18, -23, -28, -31, -34
       E1 DE
 0910  DC DE E1 E4 E9 EE      C               db -36, -34, -31, -28, -23, -18, -12, -6
       F4 FA
			      C 
