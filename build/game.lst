 353F 0D		      C threat_y     db START_Y
 3540 02		      C effect_x     db START_X
 3541 0D		      C effect_y     db START_Y
			      C ; One-shot SFX owns the speaker; music state tracks the looping theme beneath it.
 3542 00		      C sound_id     db SFX_NONE
