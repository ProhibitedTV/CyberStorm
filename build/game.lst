				include game\state.asm
			      C ; Core run state. Most symbols are referenced directly, so only the documented
			      C ; adjacency assumptions below matter to the runtime.
 2B5B 00		      C game_state   db STATE_TITLE
 2B5C 01		      C sector_num   db 1
 2B5D 05		      C shield_count db START_SHIELDS
 2B5E 03		      C pulse_count  db START_PULSES
 2B5F 00		      C data_count   db 0
 2B60 00		      C kill_count   db 0
 2B61 00		      C message_id   db MSG_SECTOR
 2B62 00		      C action_taken db 0
 2B63 02		      C player_x     db START_X
 2B64 0D		      C player_y     db START_Y
 2B65 19		      C exit_x       db EXIT_COL
 2B66 01		      C exit_y       db EXIT_ROW
			      C ; Boot drive is captured from DL on stage-two entry so post-boot bank reads do
			      C ; not depend on the boot sector staying resident.
 2B67 00		      C boot_drive   db 0
 2B68 ACE1		      C rng_state    dw 0ACE1h
 2B6A 0000		      C last_tick    dw 0
 2B6C 00		      C anim_phase   db 0
 2B6D 00		      C splash_ticks db 0
 2B6E 00		      C state_ticks  db 0
 2B6F FF		      C last_game_state db 0FFh
 2B70 00		      C feedback_timer db 0
			      C ; The runner's last committed step lets flanking hunters aim one tile ahead
			      C ; without any hidden extra turns or non-deterministic guesses.
 2B71 00		      C last_player_dx db 0
 2B72 00		      C last_player_dy db 0
			      C ; Spoof terminals briefly reroute hunters toward the gate. The timer is counted
			      C ; in enemy response phases, and spoof_x/y anchor the active route effect.
 2B73 00		      C spoof_timer  db 0
 2B74 02		      C spoof_x      db START_X
 2B75 0D		      C spoof_y      db START_Y
			      C ; threat_level and threat/effect tiles are render hints only; they telegraph
			      C ; danger and localize flashes without changing the rules.
 2B76 00		      C threat_level db THREAT_NONE
 2B77 02		      C threat_x     db START_X
 2B78 0D		      C threat_y     db START_Y
 2B79 02		      C effect_x     db START_X
 2B7A 0D		      C effect_y     db START_Y
			      C ; One-shot SFX owns the speaker; music state tracks the looping theme beneath it.
 2B7B 00		      C sound_id     db SFX_NONE
 2B7C 00		      C sound_timer  db 0
 2B7D 00		      C sound_phase  db 0
 2B7E FF		      C music_theme  db MUSIC_THEME_NONE
 2B7F 00		      C music_ticks  db 0
 2B80 00		      C music_note   db MUSIC_NOTE_REST
 2B81 0000		      C music_ptr    dw 0
 2B83 00		      C key_extended db 0
 2B84 00		      C any_key_pending db 0
 2B85 00		      C input_event_count db 0
 2B86 00		      C input_last_code db 0
 2B87 00		      C input_check_count db 0
 2B88 00		      C input_poll_count db 0
 2B89 00		      C input_last_polled db 0
 2B8A 00		      C pressed_enter db 0
 2B8B 00		      C pressed_w db 0
 2B8C 00		      C pressed_a db 0
 2B8D 00		      C pressed_s db 0
 2B8E 00		      C pressed_d db 0
 2B8F 00		      C pressed_c db 0
 2B90 00		      C pressed_up db 0
 2B91 00		      C pressed_left db 0
 2B92 00		      C pressed_right db 0
 2B93 00		      C pressed_down db 0
			      C ; key_down and key_pressed must stay adjacent because reset_keyboard_state
			      C ; clears one contiguous KEY_STATE_REGION_BYTES block starting here.
 2B94  0100 [		      C key_down db KEY_STATE_TABLE_BYTES dup (0)
        00
       ]
			      C ; Reserved for future/diagnostic per-scan bookkeeping.
 2C94  0100 [		      C key_pressed db KEY_STATE_TABLE_BYTES dup (0)
        00
       ]
