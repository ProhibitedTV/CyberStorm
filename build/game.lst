				include game\state.asm
			      C ; Core run state. Most symbols are referenced directly, so only the documented
			      C ; adjacency assumptions below matter to the runtime.
 5F19 00		      C game_state   db STATE_TITLE
 5F1A 01		      C sector_num   db 1
			      C ; current_template_index keeps the selected authored map slot so hybrid anchor
			      C ; placement can read the right generated tables after copy_sector_layout.
 5F1B 00		      C current_template_index db 0
			      C ; shard_pool_pick_mask is a sector-load scratch bitmask used while selecting
			      C ; 4 unique live shard positions from the authored 6-tile scenario pool.
 5F1C 00		      C shard_pool_pick_mask db 0
 5F1D 05		      C shield_count db START_SHIELDS
 5F1E 03		      C pulse_count  db START_PULSES
 5F1F 00		      C data_count   db 0
 5F20 00		      C kill_count   db 0
 5F21 0000		      C score_total  dw 0
 5F23 0000		      C sector_score dw 0
			      C ; Sector mastery stays small and explainable: turn count feeds fast-clear bonus,
			      C ; hits gate the clean-sector bonus, and pulse usage gates the efficiency bonus.
 5F25 00		      C sector_actions     db 0
 5F26 00		      C sector_hits        db 0
 5F27 00		      C sector_pulses_used db 0
 5F28 00		      C message_id   db MSG_SECTOR
 5F29 00		      C action_taken db 0
 5F2A 02		      C player_x     db START_X
 5F2B 0D		      C player_y     db START_Y
 5F2C 19		      C exit_x       db EXIT_COL
 5F2D 01		      C exit_y       db EXIT_ROW
			      C ; Boot drive is captured from DL on stage-two entry so post-boot bank reads do
			      C ; not depend on the boot sector staying resident.
 5F2E 00		      C boot_drive   db 0
 5F2F ACE1		      C rng_state    dw 0ACE1h
 5F31 0000		      C last_tick    dw 0
 5F33 00		      C anim_phase   db 0
 5F34 00		      C splash_ticks db 0
 5F35 00		      C state_ticks  db 0
 5F36 00		      C title_idle_ticks db 0
			      C ; A short post-start guard keeps freshly entered runs from immediately honoring
			      C ; reset input on the next gameplay tick while frontend keys are settling.
 5F37 00		      C run_start_enter_guard db 0
			      C ; Demo playback is opt-in attract mode driven by generated [action, ticks]
			      C ; pairs. next_demo_index rotates the title idle cycle through the authored set.
 5F38 00		      C demo_active  db 0
 5F39 00		      C demo_index   db 0
 5F3A 00		      C next_demo_index db 0
 5F3B 00		      C demo_action_code db DEMO_ACTION_END
 5F3C 00		      C demo_action_ticks db 0
 5F3D 0000		      C demo_script_ptr dw 0
			      C ; Debug-only replay verification tracks consumed demo actions separately from
			      C ; action_taken so blocked moves and other no-turn inputs can still be checked.
 5F3F 00		      C verify_action_pending db 0
 5F40 00		      C verify_action_index db 0
 5F41 00		      C verify_result_demo_index db 0
 5F42 0000		      C verify_expected_signature dw 0
 5F44 0000		      C verify_observed_signature dw 0
			      C ; verify_mode reuses the shared PASS/FAIL scenes for both replay verification
			      C ; and the debug-only frontend trust scenarios.
 5F46 00		      C verify_mode db VERIFY_MODE_REPLAY
 5F47 00		      C verify_frontend_scenario db FRONTEND_VERIFY_NONE
 5F48 00		      C verify_frontend_ticks db 0
 5F49 00		      C verify_frontend_event_fired db 0
 5F4A FF		      C last_game_state db 0FFh
 5F4B 00		      C feedback_timer db 0
			      C ; The runner's last committed step lets flanking hunters aim one tile ahead
			      C ; without any hidden extra turns or non-deterministic guesses.
 5F4C 00		      C last_player_dx db 0
 5F4D 00		      C last_player_dy db 0
			      C ; Spoof terminals briefly reroute hunters toward the gate. The timer is counted
			      C ; in enemy response phases, and spoof_x/y anchor the active route effect.
 5F4E 00		      C spoof_timer  db 0
 5F4F 02		      C spoof_x      db START_X
 5F50 0D		      C spoof_y      db START_Y
			      C ; threat_level and threat/effect tiles are render hints only; they telegraph
			      C ; danger and localize flashes without changing the rules.
 5F51 00		      C threat_level db THREAT_NONE
 5F52 02		      C threat_x     db START_X
 5F53 0D		      C threat_y     db START_Y
 5F54 02		      C effect_x     db START_X
 5F55 0D		      C effect_y     db START_Y
			      C ; One-shot SFX owns the speaker; music state tracks the looping theme beneath it.
 5F56 00		      C sound_id     db SFX_NONE
 5F57 00		      C sound_timer  db 0
 5F58 00		      C sound_phase  db 0
 5F59 FF		      C music_theme  db MUSIC_THEME_NONE
