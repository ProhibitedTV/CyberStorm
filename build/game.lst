 0EF5  B0 01		      C     mov al, 01h
 0EF7  2E: 8A 16 42C9 R	      C     mov dl, [boot_drive]
 0EFC  CD 13		      C     int 13h
 0EFE  72 08		      C     jc read_floppy_lba_fail
 0F00  81 C3 0200	      C     add bx, FLOPPY_SECTOR_BYTES
 0F04  46		      C     inc si
 0F05  4F		      C     dec di
