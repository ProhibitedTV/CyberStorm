 EBDC  3F 12 12		      C              db 63,18,18
 EBDF  0C 10 16		      C              db 12,16,22
 EBE2  14 1C 26		      C              db 20,28,38
 EBE5  06 0C 10		      C              db 6,12,16
 EBE8  0A 14 18		      C              db 10,20,24
 EBEB  0A 2E 34		      C              db 10,46,52
 EBEE  32 0C 12		      C              db 50,12,18
 EBF1  12 3C 38		      C              db 18,60,56
 EBF4 = 0036		      C PALETTE_BYTES equ ($ - palette_data)
 EBF4  0100 [		      C palette_rgb565_table dw 256 dup (0)
        0000
       ]
			      C 
			      C ; Only the environment-facing DAC entries breathe at runtime. Player/enemy/UI
			      C ; colors stay stable so the board remains easy to read while sectors feel live.
 EDF4 0C 10 16 14 1C 26	      C palette_scout_cycle db 12,16,22, 20,28,38, 6,12,16, 10,20,24
       06 0C 10 0A 14 18
