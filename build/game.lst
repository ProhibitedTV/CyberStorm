				include game\state.asm
			      C ; Core run state. Most symbols are referenced directly, so only the documented
			      C ; adjacency assumptions below matter to the runtime.
 302C 00		      C game_state   db STATE_TITLE
 302D 01		      C sector_num   db 1
 302E 05		      C shield_count db START_SHIELDS
 302F 03		      C pulse_count  db START_PULSES
 3030 00		      C data_count   db 0
 3031 00		      C kill_count   db 0
 3032 0000		      C score_total  dw 0
 3034 0000		      C sector_score dw 0
			      C ; Sector mastery stays small and explainable: turn count feeds fast-clear bonus,
			      C ; hits gate the clean-sector bonus, and pulse usage gates the efficiency bonus.
 3036 00		      C sector_actions     db 0
 3037 00		      C sector_hits        db 0
 3038 00		      C sector_pulses_used db 0
 3039 00		      C message_id   db MSG_SECTOR
 303A 00		      C action_taken db 0
 303B 02		      C player_x     db START_X
 303C 0D		      C player_y     db START_Y
 303D 19		      C exit_x       db EXIT_COL
 303E 01		      C exit_y       db EXIT_ROW
			      C ; Boot drive is captured from DL on stage-two entry so post-boot bank reads do
			      C ; not depend on the boot sector staying resident.
 303F 00		      C boot_drive   db 0
 3040 ACE1		      C rng_state    dw 0ACE1h
 3042 0000		      C last_tick    dw 0
 3044 00		      C anim_phase   db 0
 3045 00		      C splash_ticks db 0
 3046 00		      C state_ticks  db 0
 3047 00		      C title_idle_ticks db 0
			      C ; Demo playback is opt-in attract mode driven by generated [action, ticks]
			      C ; pairs. next_demo_index rotates the title idle cycle through the authored set.
 3048 00		      C demo_active  db 0
 3049 00		      C demo_index   db 0
 304A 00		      C next_demo_index db 0
 304B 00		      C demo_action_code db DEMO_ACTION_END
 304C 00		      C demo_action_ticks db 0
 304D 0000		      C demo_script_ptr dw 0
 304F FF		      C last_game_state db 0FFh
 3050 00		      C feedback_timer db 0
			      C ; The runner's last committed step lets flanking hunters aim one tile ahead
			      C ; without any hidden extra turns or non-deterministic guesses.
 3051 00		      C last_player_dx db 0
 3052 00		      C last_player_dy db 0
			      C ; Spoof terminals briefly reroute hunters toward the gate. The timer is counted
			      C ; in enemy response phases, and spoof_x/y anchor the active route effect.
 3053 00		      C spoof_timer  db 0
 3054 02		      C spoof_x      db START_X
 3055 0D		      C spoof_y      db START_Y
			      C ; threat_level and threat/effect tiles are render hints only; they telegraph
			      C ; danger and localize flashes without changing the rules.
 3056 00		      C threat_level db THREAT_NONE
 3057 02		      C threat_x     db START_X
 3058 0D		      C threat_y     db START_Y
 3059 02		      C effect_x     db START_X
 305A 0D		      C effect_y     db START_Y
			      C ; One-shot SFX owns the speaker; music state tracks the looping theme beneath it.
 305B 00		      C sound_id     db SFX_NONE
 305C 00		      C sound_timer  db 0
 305D 00		      C sound_phase  db 0
 305E FF		      C music_theme  db MUSIC_THEME_NONE
 305F 00		      C music_ticks  db 0
 3060 00		      C music_note   db MUSIC_NOTE_REST
 3061 0000		      C music_ptr    dw 0
