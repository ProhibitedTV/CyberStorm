				include game\state.asm
			      C ; Core run state. Most symbols are referenced directly, so only the documented
			      C ; adjacency assumptions below matter to the runtime.
 34DF 00		      C game_state   db STATE_TITLE
 34E0 01		      C sector_num   db 1
 34E1 05		      C shield_count db START_SHIELDS
 34E2 03		      C pulse_count  db START_PULSES
 34E3 00		      C data_count   db 0
 34E4 00		      C kill_count   db 0
 34E5 0000		      C score_total  dw 0
 34E7 0000		      C sector_score dw 0
			      C ; Sector mastery stays small and explainable: turn count feeds fast-clear bonus,
			      C ; hits gate the clean-sector bonus, and pulse usage gates the efficiency bonus.
 34E9 00		      C sector_actions     db 0
 34EA 00		      C sector_hits        db 0
 34EB 00		      C sector_pulses_used db 0
 34EC 00		      C message_id   db MSG_SECTOR
 34ED 00		      C action_taken db 0
 34EE 02		      C player_x     db START_X
 34EF 0D		      C player_y     db START_Y
 34F0 19		      C exit_x       db EXIT_COL
 34F1 01		      C exit_y       db EXIT_ROW
			      C ; Boot drive is captured from DL on stage-two entry so post-boot bank reads do
			      C ; not depend on the boot sector staying resident.
 34F2 00		      C boot_drive   db 0
 34F3 ACE1		      C rng_state    dw 0ACE1h
 34F5 0000		      C last_tick    dw 0
 34F7 00		      C anim_phase   db 0
 34F8 00		      C splash_ticks db 0
 34F9 00		      C state_ticks  db 0
 34FA 00		      C title_idle_ticks db 0
			      C ; Demo playback is opt-in attract mode driven by generated [action, ticks]
			      C ; pairs. next_demo_index rotates the title idle cycle through the authored set.
 34FB 00		      C demo_active  db 0
 34FC 00		      C demo_index   db 0
 34FD 00		      C next_demo_index db 0
 34FE 00		      C demo_action_code db DEMO_ACTION_END
 34FF 00		      C demo_action_ticks db 0
 3500 0000		      C demo_script_ptr dw 0
 3502 FF		      C last_game_state db 0FFh
 3503 00		      C feedback_timer db 0
			      C ; The runner's last committed step lets flanking hunters aim one tile ahead
			      C ; without any hidden extra turns or non-deterministic guesses.
 3504 00		      C last_player_dx db 0
 3505 00		      C last_player_dy db 0
			      C ; Spoof terminals briefly reroute hunters toward the gate. The timer is counted
			      C ; in enemy response phases, and spoof_x/y anchor the active route effect.
 3506 00		      C spoof_timer  db 0
 3507 02		      C spoof_x      db START_X
 3508 0D		      C spoof_y      db START_Y
			      C ; threat_level and threat/effect tiles are render hints only; they telegraph
			      C ; danger and localize flashes without changing the rules.
 3509 00		      C threat_level db THREAT_NONE
 350A 02		      C threat_x     db START_X
 350B 0D		      C threat_y     db START_Y
 350C 02		      C effect_x     db START_X
 350D 0D		      C effect_y     db START_Y
			      C ; One-shot SFX owns the speaker; music state tracks the looping theme beneath it.
 350E 00		      C sound_id     db SFX_NONE
 350F 00		      C sound_timer  db 0
 3510 00		      C sound_phase  db 0
 3511 FF		      C music_theme  db MUSIC_THEME_NONE
