 0DD2  B0 01		      C     mov al, 01h
 0DD4  2E: 8A 16 34D8 R	      C     mov dl, [boot_drive]
 0DD9  CD 13		      C     int 13h
 0DDB  72 08		      C     jc read_floppy_lba_fail
 0DDD  81 C3 0200	      C     add bx, FLOPPY_SECTOR_BYTES
 0DE1  46		      C     inc si
 0DE2  4F		      C     dec di
 0DE3  EB E2		      C     jmp read_floppy_lba_loop
			      C 
 0DE5			      C read_floppy_lba_fail:
