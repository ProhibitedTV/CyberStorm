				include game\state.asm
			      C ; Core run state. Most symbols are referenced directly, so only the documented
			      C ; adjacency assumptions below matter to the runtime.
 68FC 00		      C game_state   db STATE_TITLE
 68FD 01		      C sector_num   db 1
			      C ; current_template_index keeps the selected authored map slot so hybrid anchor
			      C ; placement can read the right generated tables after copy_sector_layout.
 68FE 00		      C current_template_index db 0
			      C ; shard_pool_pick_mask is a sector-load scratch bitmask used while selecting
			      C ; 4 unique live shard positions from the authored 6-tile scenario pool.
 68FF 00		      C shard_pool_pick_mask db 0
 6900 05		      C shield_count db START_SHIELDS
 6901 03		      C pulse_count  db START_PULSES
 6902 00		      C data_count   db 0
 6903 00		      C kill_count   db 0
 6904 0000		      C score_total  dw 0
 6906 0000		      C sector_score dw 0
			      C ; Sector mastery stays small and explainable: turn count feeds fast-clear bonus,
			      C ; hits gate the clean-sector bonus, and pulse usage gates the efficiency bonus.
 6908 00		      C sector_actions     db 0
 6909 00		      C sector_hits        db 0
 690A 00		      C sector_pulses_used db 0
 690B 00		      C message_id   db MSG_SECTOR
 690C 00		      C action_taken db 0
 690D 02		      C player_x     db START_X
 690E 0D		      C player_y     db START_Y
 690F 19		      C exit_x       db EXIT_COL
 6910 01		      C exit_y       db EXIT_ROW
			      C ; Boot drive is captured from DL on stage-two entry so post-boot bank reads do
			      C ; not depend on the boot sector staying resident.
 6911 00		      C boot_drive   db 0
 6912 ACE1		      C rng_state    dw 0ACE1h
 6914 0000		      C last_tick    dw 0
 6916 00		      C anim_phase   db 0
 6917 00		      C splash_ticks db 0
 6918 00		      C state_ticks  db 0
 6919 00		      C title_idle_ticks db 0
			      C ; A short post-start guard keeps freshly entered runs from immediately honoring
			      C ; reset input on the next gameplay tick while frontend keys are settling.
 691A 00		      C run_start_enter_guard db 0
			      C ; Demo playback is opt-in attract mode driven by generated [action, ticks]
			      C ; pairs. next_demo_index rotates the title idle cycle through the authored set.
 691B 00		      C demo_active  db 0
 691C 00		      C demo_index   db 0
 691D 00		      C next_demo_index db 0
 691E 00		      C demo_action_code db DEMO_ACTION_END
 691F 00		      C demo_action_ticks db 0
 6920 0000		      C demo_script_ptr dw 0
			      C ; Debug-only replay verification tracks consumed demo actions separately from
			      C ; action_taken so blocked moves and other no-turn inputs can still be checked.
 6922 00		      C verify_action_pending db 0
 6923 00		      C verify_action_index db 0
 6924 00		      C verify_result_demo_index db 0
 6925 0000		      C verify_expected_signature dw 0
 6927 0000		      C verify_observed_signature dw 0
			      C ; verify_mode reuses the shared PASS/FAIL scenes for both replay verification
			      C ; and the debug-only frontend trust scenarios.
 6929 00		      C verify_mode db VERIFY_MODE_REPLAY
 692A 00		      C verify_frontend_scenario db FRONTEND_VERIFY_NONE
 692B 00		      C verify_frontend_ticks db 0
 692C 00		      C verify_frontend_event_fired db 0
 692D FF		      C last_game_state db 0FFh
 692E 00		      C feedback_timer db 0
			      C ; The runner's last committed step lets flanking hunters aim one tile ahead
			      C ; without any hidden extra turns or non-deterministic guesses.
 692F 00		      C last_player_dx db 0
