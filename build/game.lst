 107F  F9		      C     stc
 1080  EB 01		      C     jmp read_floppy_lba_exit
			      C 
 1082			      C read_floppy_lba_done:
 1082  F8		      C     clc
			      C 
 1083			      C read_floppy_lba_exit:
