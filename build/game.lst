 70E5 0000		      C last_tick    dw 0
 70E7 00		      C anim_phase   db 0
 70E8 00		      C splash_ticks db 0
 70E9 00		      C state_ticks  db 0
 70EA 00		      C title_idle_ticks db 0
			      C ; A short post-start guard keeps freshly entered runs from immediately honoring
			      C ; reset input on the next gameplay tick while frontend keys are settling.
 70EB 00		      C run_start_enter_guard db 0
			      C ; Demo playback is opt-in attract mode driven by generated [action, ticks]
			      C ; pairs. next_demo_index rotates the title idle cycle through the authored set.
 70EC 00		      C demo_active  db 0
 70ED 00		      C demo_index   db 0
 70EE 00		      C next_demo_index db 0
 70EF 00		      C demo_action_code db DEMO_ACTION_END
 70F0 00		      C demo_action_ticks db 0
