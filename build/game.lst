			      C 
				include game\state.asm
			      C ; Core run state. Most symbols are referenced directly, so only the documented
			      C ; adjacency assumptions below matter to the runtime.
 8CCC 00		      C game_state   db STATE_TITLE
 8CCD 01		      C sector_num   db 1
			      C ; current_template_index keeps the selected authored map slot so hybrid anchor
			      C ; placement can read the right generated tables after copy_sector_layout.
 8CCE 00		      C current_template_index db 0
			      C ; shard_pool_pick_mask is a sector-load scratch bitmask used while selecting
			      C ; 4 unique live shard positions from the authored 6-tile scenario pool.
 8CCF 00		      C shard_pool_pick_mask db 0
 8CD0 05		      C shield_count db START_SHIELDS
 8CD1 03		      C pulse_count  db START_PULSES
 8CD2 00		      C data_count   db 0
 8CD3 00		      C kill_count   db 0
 8CD4 0000		      C score_total  dw 0
 8CD6 0000		      C sector_score dw 0
			      C ; Sector mastery stays small and explainable: turn count feeds fast-clear bonus,
			      C ; hits gate the clean-sector bonus, and pulse usage gates the efficiency bonus.
 8CD8 00		      C sector_actions     db 0
 8CD9 00		      C sector_hits        db 0
 8CDA 00		      C sector_pulses_used db 0
 8CDB 00		      C message_id   db MSG_SECTOR
 8CDC 00		      C action_taken db 0
 8CDD 02		      C player_x     db START_X
 8CDE 0D		      C player_y     db START_Y
 8CDF 19		      C exit_x       db EXIT_COL
 8CE0 01		      C exit_y       db EXIT_ROW
 8CE1 0000		      C adventure_player_world_x dw 0
 8CE3 FF00		      C adventure_player_world_y dw GAME3D_FLOOR_Y
 8CE5 0000		      C adventure_player_world_z dw 0
 8CE7 0000		      C adventure_player_vel_y   dw 0
 8CE9 80		      C adventure_player_yaw     db GAME3D_YAW_NORTH
 8CEA 01		      C adventure_player_grounded db 1
 8CEB 00		      C adventure_charge_timer   db 0
 8CEC 00		      C adventure_flame_timer    db 0
 8CED 00		      C adventure_enemy_tick     db 0
 8CEE 00		      C adventure_hazard_timer   db 0
 8CEF 00		      C adventure_objectives_done db 0
 8CF0 00		      C adventure_objectives_total db 0
 8CF1 00		      C adventure_intro_timer    db 0
			      C ; Boot drive is captured from DL on stage-two entry so post-boot bank reads do
			      C ; not depend on the boot sector staying resident.
