				include game\state.asm
			      C ; Core run state. Most symbols are referenced directly, so only the documented
			      C ; adjacency assumptions below matter to the runtime.
 3D8C 00		      C game_state   db STATE_TITLE
 3D8D 01		      C sector_num   db 1
			      C ; current_template_index keeps the selected authored map slot so hybrid anchor
			      C ; placement can read the right generated tables after copy_sector_layout.
 3D8E 00		      C current_template_index db 0
			      C ; shard_pool_pick_mask is a sector-load scratch bitmask used while selecting
			      C ; 4 unique live shard positions from the authored 6-tile scenario pool.
 3D8F 00		      C shard_pool_pick_mask db 0
 3D90 05		      C shield_count db START_SHIELDS
 3D91 03		      C pulse_count  db START_PULSES
 3D92 00		      C data_count   db 0
 3D93 00		      C kill_count   db 0
 3D94 0000		      C score_total  dw 0
 3D96 0000		      C sector_score dw 0
			      C ; Sector mastery stays small and explainable: turn count feeds fast-clear bonus,
			      C ; hits gate the clean-sector bonus, and pulse usage gates the efficiency bonus.
 3D98 00		      C sector_actions     db 0
 3D99 00		      C sector_hits        db 0
 3D9A 00		      C sector_pulses_used db 0
 3D9B 00		      C message_id   db MSG_SECTOR
 3D9C 00		      C action_taken db 0
 3D9D 02		      C player_x     db START_X
 3D9E 0D		      C player_y     db START_Y
 3D9F 19		      C exit_x       db EXIT_COL
 3DA0 01		      C exit_y       db EXIT_ROW
			      C ; Boot drive is captured from DL on stage-two entry so post-boot bank reads do
			      C ; not depend on the boot sector staying resident.
 3DA1 00		      C boot_drive   db 0
 3DA2 ACE1		      C rng_state    dw 0ACE1h
 3DA4 0000		      C last_tick    dw 0
 3DA6 00		      C anim_phase   db 0
 3DA7 00		      C splash_ticks db 0
 3DA8 00		      C state_ticks  db 0
 3DA9 00		      C title_idle_ticks db 0
			      C ; A short post-start guard keeps freshly entered runs from immediately honoring
			      C ; reset input on the next gameplay tick while frontend keys are settling.
 3DAA 00		      C run_start_enter_guard db 0
			      C ; Demo playback is opt-in attract mode driven by generated [action, ticks]
			      C ; pairs. next_demo_index rotates the title idle cycle through the authored set.
 3DAB 00		      C demo_active  db 0
 3DAC 00		      C demo_index   db 0
 3DAD 00		      C next_demo_index db 0
 3DAE 00		      C demo_action_code db DEMO_ACTION_END
 3DAF 00		      C demo_action_ticks db 0
 3DB0 0000		      C demo_script_ptr dw 0
			      C ; Debug-only replay verification tracks consumed demo actions separately from
			      C ; action_taken so blocked moves and other no-turn inputs can still be checked.
 3DB2 00		      C verify_action_pending db 0
 3DB3 00		      C verify_action_index db 0
 3DB4 00		      C verify_result_demo_index db 0
 3DB5 0000		      C verify_expected_signature dw 0
 3DB7 0000		      C verify_observed_signature dw 0
 3DB9 FF		      C last_game_state db 0FFh
 3DBA 00		      C feedback_timer db 0
			      C ; The runner's last committed step lets flanking hunters aim one tile ahead
			      C ; without any hidden extra turns or non-deterministic guesses.
 3DBB 00		      C last_player_dx db 0
 3DBC 00		      C last_player_dy db 0
			      C ; Spoof terminals briefly reroute hunters toward the gate. The timer is counted
			      C ; in enemy response phases, and spoof_x/y anchor the active route effect.
 3DBD 00		      C spoof_timer  db 0
 3DBE 02		      C spoof_x      db START_X
 3DBF 0D		      C spoof_y      db START_Y
			      C ; threat_level and threat/effect tiles are render hints only; they telegraph
			      C ; danger and localize flashes without changing the rules.
 3DC0 00		      C threat_level db THREAT_NONE
 3DC1 02		      C threat_x     db START_X
 3DC2 0D		      C threat_y     db START_Y
 3DC3 02		      C effect_x     db START_X
 3DC4 0D		      C effect_y     db START_Y
			      C ; One-shot SFX owns the speaker; music state tracks the looping theme beneath it.
 3DC5 00		      C sound_id     db SFX_NONE
 3DC6 00		      C sound_timer  db 0
 3DC7 00		      C sound_phase  db 0
 3DC8 FF		      C music_theme  db MUSIC_THEME_NONE
 3DC9 00		      C music_ticks  db 0
 3DCA 00		      C music_note   db MUSIC_NOTE_REST
 3DCB 0000		      C music_ptr    dw 0
 3DCD 00		      C key_extended db 0
 3DCE 00		      C any_key_pending db 0
 3DCF 00		      C input_event_count db 0
 3DD0 00		      C input_last_code db 0
 3DD1 00		      C input_check_count db 0
 3DD2 00		      C input_poll_count db 0
 3DD3 00		      C input_last_polled db 0
 3DD4 00		      C pressed_enter db 0
 3DD5 00		      C pressed_w db 0
 3DD6 00		      C pressed_a db 0
 3DD7 00		      C pressed_s db 0
 3DD8 00		      C pressed_d db 0
 3DD9 00		      C pressed_r db 0
 3DDA 00		      C pressed_c db 0
 3DDB 00		      C pressed_up db 0
 3DDC 00		      C pressed_left db 0
 3DDD 00		      C pressed_right db 0
 3DDE 00		      C pressed_down db 0
			      C ; key_down and key_pressed must stay adjacent because reset_keyboard_state
			      C ; clears one contiguous KEY_STATE_REGION_BYTES block starting here.
 3DDF  0100 [		      C key_down db KEY_STATE_TABLE_BYTES dup (0)
        00
       ]
			      C ; Reserved for future/diagnostic per-scan bookkeeping.
 3EDF  0100 [		      C key_pressed db KEY_STATE_TABLE_BYTES dup (0)
        00
       ]
