				include game\state.asm
			      C ; Core run state. Most symbols are referenced directly, so only the documented
			      C ; adjacency assumptions below matter to the runtime.
 6494 00		      C game_state   db STATE_TITLE
 6495 01		      C sector_num   db 1
			      C ; current_template_index keeps the selected authored map slot so hybrid anchor
			      C ; placement can read the right generated tables after copy_sector_layout.
 6496 00		      C current_template_index db 0
			      C ; shard_pool_pick_mask is a sector-load scratch bitmask used while selecting
			      C ; 4 unique live shard positions from the authored 6-tile scenario pool.
 6497 00		      C shard_pool_pick_mask db 0
 6498 05		      C shield_count db START_SHIELDS
 6499 03		      C pulse_count  db START_PULSES
 649A 00		      C data_count   db 0
 649B 00		      C kill_count   db 0
 649C 0000		      C score_total  dw 0
 649E 0000		      C sector_score dw 0
			      C ; Sector mastery stays small and explainable: turn count feeds fast-clear bonus,
			      C ; hits gate the clean-sector bonus, and pulse usage gates the efficiency bonus.
 64A0 00		      C sector_actions     db 0
 64A1 00		      C sector_hits        db 0
 64A2 00		      C sector_pulses_used db 0
 64A3 00		      C message_id   db MSG_SECTOR
 64A4 00		      C action_taken db 0
 64A5 02		      C player_x     db START_X
 64A6 0D		      C player_y     db START_Y
 64A7 19		      C exit_x       db EXIT_COL
 64A8 01		      C exit_y       db EXIT_ROW
			      C ; Boot drive is captured from DL on stage-two entry so post-boot bank reads do
			      C ; not depend on the boot sector staying resident.
 64A9 00		      C boot_drive   db 0
 64AA ACE1		      C rng_state    dw 0ACE1h
 64AC 0000		      C last_tick    dw 0
 64AE 00		      C anim_phase   db 0
 64AF 00		      C splash_ticks db 0
 64B0 00		      C state_ticks  db 0
 64B1 00		      C title_idle_ticks db 0
			      C ; A short post-start guard keeps freshly entered runs from immediately honoring
			      C ; reset input on the next gameplay tick while frontend keys are settling.
 64B2 00		      C run_start_enter_guard db 0
			      C ; Demo playback is opt-in attract mode driven by generated [action, ticks]
			      C ; pairs. next_demo_index rotates the title idle cycle through the authored set.
 64B3 00		      C demo_active  db 0
 64B4 00		      C demo_index   db 0
 64B5 00		      C next_demo_index db 0
 64B6 00		      C demo_action_code db DEMO_ACTION_END
 64B7 00		      C demo_action_ticks db 0
 64B8 0000		      C demo_script_ptr dw 0
			      C ; Debug-only replay verification tracks consumed demo actions separately from
			      C ; action_taken so blocked moves and other no-turn inputs can still be checked.
 64BA 00		      C verify_action_pending db 0
 64BB 00		      C verify_action_index db 0
 64BC 00		      C verify_result_demo_index db 0
 64BD 0000		      C verify_expected_signature dw 0
 64BF 0000		      C verify_observed_signature dw 0
			      C ; verify_mode reuses the shared PASS/FAIL scenes for both replay verification
			      C ; and the debug-only frontend trust scenarios.
 64C1 00		      C verify_mode db VERIFY_MODE_REPLAY
 64C2 00		      C verify_frontend_scenario db FRONTEND_VERIFY_NONE
 64C3 00		      C verify_frontend_ticks db 0
 64C4 00		      C verify_frontend_event_fired db 0
 64C5 FF		      C last_game_state db 0FFh
 64C6 00		      C feedback_timer db 0
			      C ; The runner's last committed step lets flanking hunters aim one tile ahead
			      C ; without any hidden extra turns or non-deterministic guesses.
 64C7 00		      C last_player_dx db 0
 64C8 00		      C last_player_dy db 0
			      C ; Spoof terminals briefly reroute hunters toward the gate. The timer is counted
			      C ; in enemy response phases, and spoof_x/y anchor the active route effect.
 64C9 00		      C spoof_timer  db 0
 64CA 02		      C spoof_x      db START_X
 64CB 0D		      C spoof_y      db START_Y
			      C ; threat_level and threat/effect tiles are render hints only; they telegraph
			      C ; danger and localize flashes without changing the rules.
 64CC 00		      C threat_level db THREAT_NONE
 64CD 02		      C threat_x     db START_X
 64CE 0D		      C threat_y     db START_Y
 64CF 02		      C effect_x     db START_X
 64D0 0D		      C effect_y     db START_Y
			      C ; One-shot SFX owns the speaker; music state tracks the looping theme beneath it.
 64D1 00		      C sound_id     db SFX_NONE
 64D2 00		      C sound_timer  db 0
 64D3 00		      C sound_phase  db 0
 64D4 FF		      C music_theme  db MUSIC_THEME_NONE
 64D5 00		      C music_ticks  db 0
 64D6 00		      C music_note   db MUSIC_NOTE_REST
 64D7 0000		      C music_ptr    dw 0
