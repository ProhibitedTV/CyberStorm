 1018  BA 7000		      C     mov dx, MAP_BANK_SEG
 101B  BE 10BC R	      C     mov si, offset text_map_bank_error
 101E  E8 0024		      C     call load_asset_bank_or_fail
			      C 
 1021  B8 0076		      C     mov ax, PRESENT_BANK_LBA
 1024  B9 0027		      C     mov cx, PRESENT_BANK_SECTORS
 1027  BA 7800		      C     mov dx, PRESENT_BANK_SEG
 102A  BE 10D6 R	      C     mov si, offset text_presentation_bank_error
