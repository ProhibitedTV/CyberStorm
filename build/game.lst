 0DEF			      C lba_to_chs:
			      C     ; Convert a 0-based floppy LBA in AX into BIOS CHS registers for int 13h.
 0DEF  50		      C     push ax
 0DF0  53		      C     push bx
 0DF1  33 D2		      C     xor dx, dx
 0DF3  BB 0012		      C     mov bx, FLOPPY_SECTORS_PER_TRACK
 0DF6  F7 F3		      C     div bx
