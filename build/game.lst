			      C ; 611 samples at the current SB16 time constant lands very close to one BIOS
			      C ; tick, so the background voice can change on the same rhythm as the game loop.
 = 0263			      C AUDIO_BLOCK_SAMPLES    equ 611
 = 0080			      C AUDIO_SAMPLE_CENTER    equ 128
			      C 
 = 0000			      C MUSIC_THEME_SPLASH equ 0
 = 0001			      C MUSIC_THEME_TITLE  equ 1
 = 0002			      C MUSIC_THEME_RUN    equ 2
 = 0003			      C MUSIC_THEME_WIN    equ 3
 = 0004			      C MUSIC_THEME_LOSE   equ 4
 = 00FF			      C MUSIC_THEME_NONE   equ 0FFh
			      C 
			      C ; Generated themes are 2-byte cells:
			      C ;   <note id>, <duration in BIOS ticks>
			      C ; The transport owns theme selection, pointer rewind, and note timing. The
			      C ; voice layer turns the current transport note into a single raw tone. Because
			      C ; the hardware path is effectively monophonic, one-shot SFX always take the
			      C ; speaker while the music transport simply pauses on its current note.
 = 0000			      C MUSIC_NOTE_REST equ 0
 = 0001			      C MUSIC_NOTE_G2   equ 1
 = 0002			      C MUSIC_NOTE_A2   equ 2
 = 0003			      C MUSIC_NOTE_C3   equ 3
 = 0004			      C MUSIC_NOTE_D3   equ 4
 = 0005			      C MUSIC_NOTE_E3   equ 5
 = 0006			      C MUSIC_NOTE_F3   equ 6
 = 0007			      C MUSIC_NOTE_G3   equ 7
 = 0008			      C MUSIC_NOTE_A3   equ 8
 = 0009			      C MUSIC_NOTE_C4   equ 9
 = 000A			      C MUSIC_NOTE_D4   equ 10
 = 000B			      C MUSIC_NOTE_E4   equ 11
 = 000C			      C MUSIC_NOTE_F4   equ 12
 = 000D			      C MUSIC_NOTE_G4   equ 13
 = 00FF			      C MUSIC_NOTE_LOOP equ 0FFh
