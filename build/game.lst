				include game\state.asm
			      C ; Core run state. Most symbols are referenced directly, so only the documented
			      C ; adjacency assumptions below matter to the runtime.
 34C2 00		      C game_state   db STATE_TITLE
 34C3 01		      C sector_num   db 1
 34C4 05		      C shield_count db START_SHIELDS
 34C5 03		      C pulse_count  db START_PULSES
 34C6 00		      C data_count   db 0
 34C7 00		      C kill_count   db 0
 34C8 0000		      C score_total  dw 0
 34CA 0000		      C sector_score dw 0
			      C ; Sector mastery stays small and explainable: turn count feeds fast-clear bonus,
			      C ; hits gate the clean-sector bonus, and pulse usage gates the efficiency bonus.
 34CC 00		      C sector_actions     db 0
 34CD 00		      C sector_hits        db 0
 34CE 00		      C sector_pulses_used db 0
 34CF 00		      C message_id   db MSG_SECTOR
 34D0 00		      C action_taken db 0
 34D1 02		      C player_x     db START_X
