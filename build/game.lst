 0E01  F7 F3		      C     div bx
 0E03  8A E8		      C     mov ch, al
 0E05  8A F2		      C     mov dh, dl
 0E07  5B		      C     pop bx
 0E08  58		      C     pop ax
 0E09  C3		      C     ret
