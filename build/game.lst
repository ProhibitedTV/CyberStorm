			      C ; hits gate the clean-sector bonus, and pulse usage gates the efficiency bonus.
 9A6D 00		      C sector_actions     db 0
 9A6E 00		      C sector_hits        db 0
 9A6F 00		      C sector_pulses_used db 0
 9A70 00		      C message_id   db MSG_SECTOR
